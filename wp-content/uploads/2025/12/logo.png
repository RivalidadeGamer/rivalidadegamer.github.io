<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Logo - RivalidadeGamer</title>

  <!-- Favicon (troca o link abaixo pelo ícone que quiser) -->
  <link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/512/1/1177.png">

  <style>
    body {
      margin: 0;
      background: #000;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }
  </style>
</head>
<body>
  <!-- Troca o src abaixo pelo link da tua imagem -->
  <img src="/images/Logo/logo-sem-fundo.png" alt="Imagem">
</body>
</html>
